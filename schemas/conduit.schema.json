{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/anomalyco/Zakira.Conduit/main/schemas/conduit.schema.json",
  "title": "Zakira.Conduit manifest",
  "description": "Manifest describing skill sources to mirror into one or more local target directories.",
  "type": "object",
  "required": ["entries"],
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string" },
    "version": {
      "type": "integer",
      "const": 1,
      "description": "Manifest schema version. Must be 1."
    },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/entry" },
      "minItems": 1
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "required": ["name", "source", "targets"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._-]+$",
          "description": "Unique entry identifier. Used as the destination sub-directory name when the source produces exactly one content unit; used only for filtering / logs when the source produces multiple units."
        },
        "description": { "type": "string" },
        "disabled": { "type": "boolean", "default": false },
        "source": { "$ref": "#/$defs/source" },
        "targets": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "source": {
      "oneOf": [
        { "$ref": "#/$defs/githubSource" },
        { "$ref": "#/$defs/localSource" }
      ]
    },
    "githubSource": {
      "type": "object",
      "required": ["type", "repo"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "github" },
        "repo": {
          "type": "string",
          "minLength": 1,
          "description": "Repository identifier. Accepts a slug (owner/repo), a github.com URL, or an SSH-style reference (git@github.com:owner/repo[.git])."
        },
        "path": {
          "type": "string",
          "description": "Optional single sub-path. Mutually exclusive with 'paths'."
        },
        "paths": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "description": "Optional list of sub-paths. Mutually exclusive with 'path'. With one element the destination subdirectory uses the entry name; with two or more, each sub-path mirrors to its basename and the entry name is metadata only."
        },
        "branch": {
          "type": "string",
          "description": "Branch or tag name. Mutually exclusive with 'commit'."
        },
        "commit": {
          "type": "string",
          "description": "Commit SHA. Mutually exclusive with 'branch'."
        }
      },
      "not": {
        "anyOf": [
          { "required": ["branch", "commit"] },
          { "required": ["path", "paths"] }
        ]
      }
    },
    "localSource": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "local" },
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "Single source directory. Mutually exclusive with 'paths'."
        },
        "paths": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "description": "Multiple source directories. Mutually exclusive with 'path'."
        }
      },
      "anyOf": [
        { "required": ["path"] },
        { "required": ["paths"] }
      ],
      "not": {
        "required": ["path", "paths"]
      }
    }
  }
}
