<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Pin this repository to nuget.org only. We intentionally clear any
    inherited sources (user/machine NuGet.config) so Central Package
    Management (CPM) does not warn about ambiguous package origins, and
    so contributors/CI always restore from the same place.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
