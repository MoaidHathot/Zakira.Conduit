{
  "$schema": "../schemas/conduit.schema.json",
  "version": 1,
  "entries": [
    {
      "name": "PowerReview",
      "source": {
        "type": "github",
        "repo": "https://github.com/MoaidHathot/PowerReview",
        "paths": [
          "skills"
        ],
        "branch": "main"
      },
      "targets": [
        "~/projects/my-app/.agents/skills"
      ]
    },
    {
      "name": "internal-runbooks",
      "description": "Private runbooks pinned to a specific commit.",
      "source": {
        "type": "github",
        "repo": "my-org/agent-runbooks",
        "commit": "1f2e3d4c5b6a7980abcdef0123456789abcdef01"
      },
      "targets": [
        "$XDG_CONFIG_HOME/agents/skills"
      ]
    },

    // ---------------------------------------------------------------------
    // 4) A local skill that lives next to this manifest (relative paths
    //    are anchored at the manifest's own directory). Use this for
    //    in-house skills you check in alongside your code, or for any
    //    folder you'd otherwise `cp -R` by hand.
    // ---------------------------------------------------------------------
    {
      "name": "local-skill-sample",
      "description": "House-style skill kept in this repo. Edit the files in ./local-skill-sample and re-run `conduit sync`.",
      "source": {
        "type": "local",
        "path": "./local-skill-sample"
      },
      "targets": [
        "~/.config/claude/skills",
        "~/projects/my-app/.agents/skills"
      ]
    },

    // ---------------------------------------------------------------------
    // 5) Multiple local directories in one entry. Each directory mirrors
    //    into every target as its own basename sub-folder.
    // ---------------------------------------------------------------------
    {
      "name": "local-skill-bundle",
      "description": "Mirror several local directories at once.",
      "source": {
        "type": "local",
        "paths": [
          "./local-skill-sample"
          // Add more directories here as your house-skill collection grows.
        ]
      },
      "targets": [
        "~/projects/my-app/.agents/skills"
      ]
    },

    // ---------------------------------------------------------------------
    // 6) An entry parked but kept in the manifest for documentation.
    //    `conduit sync` skips this one until you flip `disabled` back.
    // ---------------------------------------------------------------------
    {
      "name": "experimental-thing",
      "description": "Not ready for prime time yet \u2014 set 'disabled' to false to enable.",
      "disabled": true,
      "source": {
        "type": "github",
        "repo": "octocat/experimental-skills"
      },
      "targets": [
        "~/.config/claude/skills"
      ]
    }

  ]
}
